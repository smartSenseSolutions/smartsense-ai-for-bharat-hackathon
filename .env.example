# ── Docker Compose Environment Variables ───────────────────────────────
# Copy this file to .env and fill in the values before running:
#   docker compose up -d

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=procure_ai
DB_PORT=5432

# ── Service Ports ──────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend Build Args ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Backend Application Settings ──────────────────────────────────────
# (These are passed to the backend container via env_file)
# DATABASE_URL is auto-generated in docker-compose.yml from POSTGRES_* vars

# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Exa API Search
EXA_API_KEY=your_exa_api_key

# OpenSearch Serverless
OPENSEARCH_URL=your_opensearch_endpoint

# Bedrock Model IDs
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_NOVA_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# JWT Authentication
JWT_SECRET_KEY=your_very_long_random_secret_key_here

# Vendor Smart Search
VENDOR_SEARCH_TOP_N=3
VENDOR_SEARCH_EXTERNAL_N=3
VENDOR_SEARCH_KEYWORD_WEIGHT=0.4
VENDOR_SEARCH_VECTOR_WEIGHT=0.6
VENDOR_SEARCH_CANDIDATE_MULTIPLIER=10

# Nylas Email Integration
NYLAS_API_KEY=your_nylas_api_key
NYLAS_GRANT_ID=your_nylas_grant_id
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_WEBHOOK_SECRET=your_nylas_webhook_secret
